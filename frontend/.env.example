# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# CC Avenue (Optional for frontend)
NEXT_PUBLIC_CCAVENUE_MERCHANT_ID=your_merchant_id

# Environment
NEXT_PUBLIC_ENV=development

# WhatsApp Floating Button
# Use international format, digits only recommended (e.g. 966512345678)
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_WHATSAPP_MESSAGE=Hello, I would like to know more about your travel packages.
